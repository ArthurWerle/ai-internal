# ai-internal service — example environment file.
#
# Copy to `stack.env` (gitignored) and fill in real values. docker-compose.yml
# and docker-compose.staging.yml load it via `env_file: stack.env`, and the local
# dev/migrate tasks read it via `--env=stack.env` (see deno.json).
#
# Vars marked REQUIRED must be present or the container will not start (it will
# crash-loop, which callers such as the reports service see as
# "connection refused" on http://ai-internal:3005).

# --- REQUIRED at boot ---
# Without this the OpenRouterService constructor throws at startup and the
# process exits (main.ts assertRequiredEnv now reports it explicitly).
OPENROUTER_API_KEY=sk-or-...

# Postgres (compose builds DATABASE_URL from these; the migrate step exits if the
# DB is unreachable, before the HTTP server starts). Required for local dev too.
POSTGRES_USER=ai_internal
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ai_internal_db
# For local `deno task dev`/`migrate` outside compose, also set DATABASE_URL
# directly (compose overrides it to point at the `postgres` service):
# DATABASE_URL=postgres://ai_internal:change-me@localhost:5439/ai_internal_db

# Langfuse telemetry keys (read at import time in config/langfuse.ts).
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# --- Optional (have safe defaults in code) ---
LANGFUSE_BASE_URL=https://cloud.langfuse.com
NODE_ENV=production
# MCP tool server; only used when a tool call is made.
MCP_API_URL=http://mcp-api:3006
# Model selection / behavior (config/config.ts).
# /ask agent model. This drives the interactive finance assistant, so it wants a
# strong reasoning model. Swap for an Opus-tier Anthropic model for maximum
# capability (pricier). Any OpenRouter model slug works.
AGENT_MODEL=anthropic/claude-sonnet-4.5
AGENT_RECURSION_LIMIT=40
UI_GENERATION_MODEL=anthropic/claude-sonnet-4.5
# Spending-insights model (/insights + /insights/rebuild). Defaults to an
# Opus-tier Anthropic model for the richest analysis; drop to
# anthropic/claude-sonnet-4.5 for lower cost per rebuild. Any OpenRouter slug works.
INSIGHTS_MODEL=anthropic/claude-opus-4.1
# Max output tokens for the insight (headline + detailed markdown body).
INSIGHTS_MAX_TOKENS=900
# Timezone used for report period math.
REPORTING_TIMEZONE=America/Sao_Paulo
